# Variables d'environnement pour le système d'autorisation WebSocket
# Copiez ce fichier en .env et remplissez les valeurs appropriées

# ========================================
# VARIABLES REQUISES (à configurer manuellement)
# ========================================

# Table DynamoDB pour stocker les connexions WebSocket
TABLE=your-websocket-connections-table-name

# ID du User Pool Cognito pour la validation JWT
COGNITO_POOL_ID=your-cognito-user-pool-id

# Région AWS où sont déployés vos services
REGION=us-east-1

# ========================================
# VARIABLES GÉNÉRÉES AUTOMATIQUEMENT
# (Ces variables sont définies lors du déploiement de la stack)
# ========================================

# URL de l'endpoint WebSocket (générée automatiquement par API Gateway lors du déploiement)
# WEBSOCKET_ENDPOINT_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/dev

# ========================================
# VARIABLES OPTIONNELLES
# ========================================

# Niveau de log (optionnel)
LOG_LEVEL=INFO

# ========================================
# EXEMPLE DE VALEURS POUR LE DÉVELOPPEMENT LOCAL
# ========================================

# TABLE=websocket-connections-dev
# COGNITO_POOL_ID=us-east-1_abcdef123
# REGION=us-east-1
# LOG_LEVEL=DEBUG

# Note: WEBSOCKET_ENDPOINT_URL sera automatiquement définie par votre infrastructure as code (CDK/CloudFormation)
